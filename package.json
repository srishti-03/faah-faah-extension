{
  "name": "fha-fha-extension",
  "displayName": "Faah Faah: Error Sounds & Roasts",
  "description": "Your code has errors. You will be judged. Audibly.",
  "version": "0.0.4",
  "icon":"logo.png",
  "publisher": "fhafha-devss",
  "repository": {
    "type": "git",
    "url": "https://github.com/srishti-03/faah-faah-extension"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "fha-fha-extension.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "fha-fha-extension.rageQuit",
        "title": "Fha Fha: Rage Quit"
      },
      {
        "command": "fha-fha-extension.toggleMute",
        "title": "Fha Fha: Toggle Mute"
      }
    ],
    "configuration": {
      "title": "Fha Fha",
      "properties": {
        "fhaFha.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable Faah Faah. You can also toggle from the status bar (bottom)."
        },
        "fhaFha.sirenSoundPath": {
          "type": "string",
          "default": "",
          "description": "Custom .mp3 file path for siren sound (.env errors). Leave empty for default siren."
        },
        "fhaFha.victorySoundPath": {
          "type": "string",
          "default": "",
          "description": "Custom .mp3 file path for victory sound (when all errors are fixed). Leave empty for default."
        },
        "fhaFha.errorSoundPath": {
          "type": "string",
          "default": "",
          "description": "Custom .mp3 file path for error sound. Leave empty to use default faaah sound."
        },
        "fhaFha.warningSoundPath": {
          "type": "string",
          "default": "",
          "description": "Custom path to warning sound (.mp3). Leave empty to disable warning sounds"
        },
        "fhaFha.debounceMs": {
          "type": "number",
          "default": 1500,
          "description":"Delay (ms) before sound triggers after an error. Increase to avoid mid-typing sounds. Default: 1500ms"

        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "webpack": "^5.104.1",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "sound-play": "^1.1.0"
  }
}